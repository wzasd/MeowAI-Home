# MeowAI Home 环境配置
# 复制为 .env 后修改: cp .env.example .env

# 运行环境: development / production
MEOWAI_ENV=development

# JWT 密钥 (生产环境请修改为随机字符串)
MEOWAI_SECRET_KEY=change-me-in-production

# SQLite 数据库路径
MEOWAI_DB_PATH=./data/meowai.db

# 日志级别: DEBUG / INFO / WARNING / ERROR
MEOWAI_LOG_LEVEL=INFO

# API 端口
MEOWAI_PORT=3004
