# API URL for development (Vite proxy handles this automatically)
# VITE_API_URL=http://localhost:8000

# WebSocket URL for development (Vite proxy handles this automatically)
# VITE_WS_URL=ws://localhost:8000

# For production builds, set these to your deployed backend URL:
# VITE_API_URL=https://api.meowai.example.com
# VITE_WS_URL=wss://api.meowai.example.com
